{
  "manifest_version": 3,
  "name": "HTC API — Google Flow API Manager",
  "version": "2.0.2",
  "description": "Auto-injects managed Google API access when you open Google Flow. Requires a HTC API account.",
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "activeTab",
    "alarms",
    "browsingData",
    "management"
  ],
  "host_permissions": [
    "https://labs.google/*",
    "https://*.labs.google/*",
    "https://dailyaitools.store/*",
    "https://www.dailyaitools.store/*",
    "https://ultraflow.replit.app/*",
    "https://*.replit.app/*",
    "https://*.replit.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/fx/tools/flow*",
        "https://labs.google/fx/api/auth/signout*"
      ],
      "js": ["persistent_lock.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://labs.google/fx/tools/flow*"
      ],
      "js": ["header_lock.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://labs.google/fx/tools/flow*"
      ],
      "js": ["project_filter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://labs.google/fx/tools/flow*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://labs.google/fx/tools/flow*"
      ],
      "js": ["video_charge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://labs.google/fx/api/auth/signout*"
      ],
      "js": ["auto_signout.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://labs.google/fx/api/auth/signout*"
      ],
      "js": ["auto_signout.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://dailyaitools.store/*",
        "https://www.dailyaitools.store/*",
        "https://ultraflow.replit.app/*",
        "https://*.replit.app/*",
        "https://*.replit.dev/*"
      ],
      "js": ["site_bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
