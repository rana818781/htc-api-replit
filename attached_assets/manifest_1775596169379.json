{
  "manifest_version": 3,
  "name": "flow-extension-v2.1.1",
  "version": "2.1.1",
  "description": "Injects managed sessions on Google Flow with credit tracking, media detection, and session isolation.",
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "management"
  ],
  "host_permissions": [
    "https://labs.google/*",
    "https://*.labs.google/*",
    "https://*.replit.app/*",
    "https://*.replit.dev/*",
    "https://video-flow-portall.replit.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/fx/tools/flow*",
        "https://labs.google/fx/api/auth/signout*"
      ],
      "js": [
        "persistent_lock.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://labs.google/fx/tools/flow*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://labs.google/fx/api/auth/signout*"
      ],
      "js": [
        "auto_signout.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://labs.google/fx/api/auth/signout*"
      ],
      "js": [
        "auto_signout.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://*.replit.app/*",
        "https://*.replit.dev/*",
        "https://video-flow-portall.replit.app/*"
      ],
      "js": [
        "site_bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}